<Page
    x:Class="WinUI3_Senior_Gallery.Pages.MixviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="MixviewExperience" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Radial related-content graph with host-owned nodes" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="Synthetic local data only. Selecting a node updates the graph and live-region announcement; the control never navigates or loads remote content." Opacity="0.72" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Open" Click="OnOpenClick" />
            <Button Content="Close" Click="OnCloseClick" />
            <Button Content="Select root" Click="OnRootClick" />
            <ToggleButton x:Name="ReducedMotionToggle" Content="Reduced motion" Checked="OnReducedMotionChanged" Unchecked="OnReducedMotionChanged" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <controls:MixviewExperience x:Name="Mixview" MinHeight="460" NodeSelected="OnNodeSelected" Closed="OnClosed" />
        </Border>
    </Grid>
</Page>
