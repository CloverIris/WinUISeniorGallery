<Page
    x:Class="WinUI3_Senior_Gallery.Pages.GuideMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="GuideMenuExperience" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Host-owned layered guide navigation" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="Synthetic Xbox-style guide nodes. Leaf actions are reported to the host; the control never performs navigation or window changes." Opacity="0.72" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Open" Click="OnOpenClick" />
            <Button Content="Back" Click="OnBackClick" />
            <ToggleButton x:Name="DismissToggle" Content="Dismiss leaf" Checked="OnDismissChanged" Unchecked="OnDismissChanged" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <controls:GuideMenuExperience x:Name="Guide" MinHeight="460" NodeInvoked="OnNodeInvoked" NavigationChanged="OnNavigationChanged" Closed="OnClosed" />
        </Border>
    </Grid>
</Page>
