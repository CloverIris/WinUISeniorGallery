<Page
    x:Class="WinUI3_Senior_Gallery.Pages.ExperiencesIndexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="Experiences" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="由多个高级组件组合而成的完整体验。该区域用于验证主页、沉浸式播放、阅读和生产力场景的结构与体验边界。"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="开发占位页"
                Message="Catalog route: /experiences。此页仅建立导航与信息结构，不代表体验已实现。" />
            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="规划中的体验" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="HomeScreen · ImmersiveNowPlaying · WidgetsBoard · TabbedShell · FocusSession · ImmersiveReader · EditorCanvas · CaptionsTranslationExperience" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
