<Page
    x:Class="WinUI3_Senior_Gallery.Pages.HubPanoramaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="HubPanorama" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Metro-style horizontal sections with host-owned content" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="合成章节和卡片；方向键/RTL/Wrap 只改变选择，不导航到外部页面。" Opacity="0.7" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Previous" Click="OnPreviousClick" />
            <Button Content="Next" Click="OnNextClick" />
            <ToggleButton x:Name="WrapToggle" Content="Wrap" IsChecked="True" Checked="OnWrapChanged" Unchecked="OnWrapChanged" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <controls:HubPanorama x:Name="Panorama" MinHeight="360" />
        </Border>
    </Grid>
</Page>
