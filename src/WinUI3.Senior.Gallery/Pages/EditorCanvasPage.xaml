<Page
    x:Class="WinUI3_Senior_Gallery.Pages.EditorCanvasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4">
            <TextBlock Text="EditorCanvas" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Core document model + WinUI viewport / selection surface" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="本地合成对象，仅用于观察缩放、平移、选择、拖拽、吸附、删除与撤销边界；不连接文件或云服务。" Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Select" Click="OnSelectClick" />
            <Button Content="Pan" Click="OnPanClick" />
            <Button Content="Rectangle" Click="OnRectangleClick" />
            <Button Content="Text" Click="OnTextClick" />
            <Button Content="Ink" Click="OnInkClick" />
            <Button Content="Fit" Click="OnFitClick" />
            <Button Content="Undo" Click="OnUndoClick" />
            <Button Content="Redo" Click="OnRedoClick" />
            <ToggleButton x:Name="GridToggle" Content="Grid" IsChecked="True" Checked="OnGridChanged" Unchecked="OnGridChanged" />
            <ToggleButton x:Name="SnapToggle" Content="Snap 16" Checked="OnSnapChanged" Unchecked="OnSnapChanged" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="1">
            <controls:EditorCanvas x:Name="CanvasEditor" MinHeight="420" />
        </Border>
    </Grid>
</Page>
