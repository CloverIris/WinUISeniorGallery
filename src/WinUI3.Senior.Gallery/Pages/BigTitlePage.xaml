<Page
    x:Class="WinUI3_Senior_Gallery.Pages.BigTitlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <Grid Margin="28" RowSpacing="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="4">
            <TextBlock Text="BigTitle" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Scroll-aware large heading" Style="{StaticResource SubtitleTextBlockStyle}" />
        </StackPanel>
        <Border Grid.Row="1" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ScrollViewer x:Name="ScrollHost" ViewChanged="OnScrollChanged">
                <StackPanel Padding="24" Spacing="18">
                    <controls:BigTitle x:Name="Title" Text="Modern Windows" ScrollSource="{Binding ElementName=ScrollHost}" />
                    <TextBlock Text="向下滚动查看标题从 64px 渐变到紧凑标题。ScrollSource 由页面显式提供，控件不创建滚动器。" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding Paragraphs}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
