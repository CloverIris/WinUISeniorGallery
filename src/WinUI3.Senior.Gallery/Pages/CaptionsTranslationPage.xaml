<Page
    x:Class="WinUI3_Senior_Gallery.Pages.CaptionsTranslationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:WinUI3.Senior.Media">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="CaptionsTranslationExperience" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Host-provided caption revisions with translation fallback" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="Synthetic documents only. No ASR, translation provider, SRT/VTT/LRC parser, network, or selected-media subtitle claim is made by this page." TextWrapping="Wrap" Opacity="0.72" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Apply revision 1" Click="OnRevisionOneClick" />
            <Button Content="Apply revision 2" Click="OnRevisionTwoClick" />
            <Button Content="Apply stale revision" Click="OnStaleClick" />
            <ComboBox x:Name="ModeBox" Width="150" SelectionChanged="OnModeChanged">
                <ComboBoxItem Content="Single line" /><ComboBoxItem Content="Scrolling lyrics" /><ComboBoxItem Content="Karaoke" /><ComboBoxItem Content="Bilingual" />
            </ComboBox>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <media:CaptionsTranslationExperience x:Name="Experience" RevisionApplied="OnRevisionApplied" StateChanged="OnStateChanged" />
        </Border>
    </Grid>
</Page>
