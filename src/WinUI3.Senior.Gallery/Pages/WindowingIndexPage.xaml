<Page
    x:Class="WinUI3_Senior_Gallery.Pages.WindowingIndexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="Windowing" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="窗口与宿主体验的开发入口。这里将承载 WindowChrome、浮动宿主、边缘命令面板和停靠布局的交互演示。"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="开发占位页"
                Message="Catalog route: /windowing。正式示例将在对应工作单元进入 ready 后接入。" />
            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="规划中的入口" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="WindowChrome · TitleBarHost · CompactOverlayHost · FloatingWidgetHost · EdgeCommandPanel · SettingsPanel · DockLayoutPreview" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
