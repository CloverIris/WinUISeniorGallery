<Page
    x:Class="WinUI3_Senior_Gallery.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />
            <TextBlock TextWrapping="Wrap" Text="Development placeholder for Gallery-owned preferences and diagnostics. It does not alter system settings or component contracts." />
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Catalog route"
                Message="/pages/settings" />
        </StackPanel>
    </ScrollViewer>
</Page>
