<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.MediaIndexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel MaxWidth="1200" Padding="32,24,32,40" Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Text="Media" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="媒体播放与时间文本组件" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Catalog route: /media" Opacity="0.68" />
            </StackPanel>

            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="媒体功能仍由规格驱动"
                     Message="P0 先定义宿主接口和可访问性、生命周期与失败回退；此处不绑定具体媒体服务或网络 Provider。" />

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Playback chrome" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="MediaPlayerChrome 通过 IMediaPlaybackSession 与具体播放器解耦；浮窗是请求而非控件自行创建窗口。" TextWrapping="Wrap" />
                        <TextBlock Text="controls.media-player-chrome · specified" Opacity="0.68" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Timeline &amp; timed text" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="MediaTimeline、TimedTextView、字幕、歌词与 ASR/翻译抽象。" TextWrapping="Wrap" />
                        <TextBlock Text="/media/timeline · /media/timed-text" Opacity="0.68" />
                    </StackPanel>
                </Border>
                <Border Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Mini &amp; ten-foot UI" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="MiniPlayerHost 与 MediaCenterGrid 面向小窗和十英尺媒体浏览体验。" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Implementation boundary" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="当前 Gallery 只承载工作单元入口；不会请求网络、媒体权限或启动任何 Provider。" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
