<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.MediaIndexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel MaxWidth="1200" Padding="32,24,32,40" Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Text="Media" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="媒体播放与时间文本组件" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Catalog route: /media" Opacity="0.68" />
            </StackPanel>

            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="P0 media lab"
                     Message="控件通过 IMediaPlaybackSession 与引擎解耦。实验页默认不联网；播放器页只在你主动选择本地文件时创建媒体源。" />

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Button Grid.Row="1" Padding="20" HorizontalContentAlignment="Stretch" Click="OnChromeClick">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Playback chrome" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="打开本地媒体、观察播放器控制层和显式全屏/浮窗请求。" TextWrapping="Wrap" />
                        <TextBlock Text="/media/media-player-chrome · P0 lab" Opacity="0.68" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="1" Grid.Column="1" Padding="20" HorizontalContentAlignment="Stretch" Click="OnTimelineClick">
                    <StackPanel Spacing="8">
                        <TextBlock Text="MediaTimeline" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="本地确定性会话：点播、直播 DVR、缓冲、禁用区间和标记。" TextWrapping="Wrap" />
                        <TextBlock Text="/media/media-timeline · P0 lab" Opacity="0.68" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="2" Padding="20" HorizontalContentAlignment="Stretch" Click="OnMediaCenterGridClick">
                    <StackPanel Spacing="8">
                        <TextBlock Text="MediaCenterGrid" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="十英尺海报墙、方向键/手柄焦点和宿主选择事件。" TextWrapping="Wrap" />
                        <TextBlock Text="/media/media-center-grid · in-progress" Opacity="0.68" />
                    </StackPanel>
                </Button>
                <Button Padding="20" HorizontalContentAlignment="Stretch" Click="OnTimedTextClick">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TimedTextView" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="合成文本演示单行字幕、歌词、Karaoke、双语和 Revision。" TextWrapping="Wrap" />
                        <TextBlock Text="/media/timed-text-view · P0 lab" Opacity="0.68" />
                    </StackPanel>
                </Button>
                <Border Grid.Column="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Implementation boundary" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="P0 不含网络、播放列表、投屏、字幕解析、ASR 或翻译 Provider。Gallery 不保存文件路径或媒体内容。" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
