<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.ControlsWorkbenchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:senior="using:WinUI3.Senior.Controls">
    <Grid>
        <ScrollViewer Padding="32,24,32,40" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1200" Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Senior Controls Workbench" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="CommandRibbon、IconPicker、DragOverlay 和输入/命令状态的本地实验台" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Catalog route: /controls/workbench" Opacity="0.68" />
                </StackPanel>

                <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                         Title="宿主边界"
                         Message="这些控件只发出命令、选择或拖放请求；Gallery 不创建窗口、不扫描系统资源，也不持久化用户数据。" />

                <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="CommandRibbon" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <senior:CommandRibbon x:Name="CommandRibbonHost" AutomationProperties.AutomationId="ControlsWorkbench.CommandRibbon" />
                        <TextBlock x:Name="RibbonStatus" Text="等待命令" Opacity="0.68" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="IconPicker" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <senior:IconPicker x:Name="IconPickerHost" Height="260" AutomationProperties.AutomationId="ControlsWorkbench.IconPicker" />
                            <TextBlock x:Name="IconStatus" Text="尚未选择图标" TextWrapping="Wrap" Opacity="0.68" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="DragOverlay" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="由宿主提供拖放源、预览和操作权限，控件只负责可视反馈。" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Show allowed" Click="OnShowAllowedClick" />
                                <Button Content="Show forbidden" Click="OnShowForbiddenClick" />
                                <Button Content="Hide" Click="OnHideDragClick" />
                            </StackPanel>
                            <TextBlock x:Name="DragStatus" Text="拖拽反馈已隐藏" Opacity="0.68" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <senior:DragOverlay x:Name="DragOverlayHost" />
    </Grid>
</Page>
