<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel MaxWidth="1200" Padding="32,24,32,40" Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Text="WinUI 3 Senior Gallery" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="面向现代 Windows 应用的高级复合组件、体验模式与设计考古。" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Catalog route: /" Opacity="0.68" />
            </StackPanel>

            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="开发中的 Gallery 主机"
                     Message="各个入口先连接到其规格和占位页面；只有状态为 ready 的工作单元才会进入正式控件实现。" />

            <TextBlock Text="探索入口" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Controls" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="可复用的高级控件：集合、导航、布局、浮层、命令、输入与数据编辑。" TextWrapping="Wrap" />
                        <TextBlock Text="/controls" Opacity="0.68" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Media &amp; Windowing" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="媒体播放、时间文本、浮窗和窗口托管体验的实现入口。" TextWrapping="Wrap" />
                        <TextBlock Text="/media · /windowing" Opacity="0.68" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Design archaeology" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="重访 Windows、Zune、Media Center、Xbox 与 Microsoft 365 的优秀交互遗产。" TextWrapping="Wrap" />
                        <TextBlock Text="/archaeology" Opacity="0.68" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="当前进度" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="CarouselView 是第一项 P0 实施工作。其余页面此时提供稳定的导航落点与规格可见性，而不是伪装为已完成的产品体验。" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
