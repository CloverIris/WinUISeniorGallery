<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="1240" Padding="32,28,32,48" Spacing="24">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="10">
                    <TextBlock Text="WinUI 3 Senior Gallery" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="面向现代 Windows 应用的高级复合控件、体验套件与设计考古。" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                    <TextBlock Text="规格驱动 · 本地可调试 · 非微软官方项目" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                        <Button Content="打开 Playground" Click="OnOpenPlaygroundClick" />
                        <Button Content="查看项目进度" Click="OnOpenAboutClick" />
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Padding="20" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="当前工作区" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="本地确定性数据" />
                        <TextBlock Text="Gallery Debug / x64" Opacity="0.7" />
                        <ProgressBar Value="36" Maximum="100" Height="6" Margin="0,8,0,0" />
                        <TextBlock Text="4 个 P0 工作项正在实现" Opacity="0.7" />
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="这是一个可运行的规格实验室"
                     Message="页面中的数据、播放会话和诊断状态都由 Gallery 本地生成；不会联网、上传媒体或保存用户文件路径。" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FeatureSearchBox" PlaceholderText="搜索控件、体验或分类" TextChanged="OnFeatureSearchChanged" />
                <ComboBox x:Name="FeatureFilterComboBox" Grid.Column="1" SelectedIndex="0" SelectionChanged="OnFeatureCategoryChanged">
                    <ComboBoxItem Content="全部分类" />
                    <ComboBoxItem Content="Controls" />
                    <ComboBoxItem Content="Media" />
                    <ComboBoxItem Content="Windowing" />
                    <ComboBoxItem Content="Archaeology" />
                </ComboBox>
            </Grid>
            <TextBlock x:Name="FeatureCountText" Text="快速入口" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ItemsControl ItemsSource="{Binding VisibleFeatures}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button HorizontalContentAlignment="Stretch" Margin="0,0,0,10" Padding="16" Tag="{Binding Route}" Click="OnFeatureClick">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="42" Height="42" CornerRadius="21" Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="{Binding Category}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Status}" Opacity="0.65" Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="›" FontSize="28" VerticalAlignment="Center" Opacity="0.65" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Dashboard 快照" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ItemsControl ItemsSource="{Binding Widgets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16" Margin="0,0,0,10" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                    <TextBlock Text="{Binding Summary}" Opacity="0.7" />
                                    <TextBlock Text="{Binding RefreshDescription}" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Value}" VerticalAlignment="Center" FontSize="18" />
                                <Button Grid.Column="2" Content="刷新" Tag="{Binding}" Click="OnWidgetRefreshClick" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
