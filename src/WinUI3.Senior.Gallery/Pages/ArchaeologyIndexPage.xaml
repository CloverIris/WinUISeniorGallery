<Page
    x:Class="WinUI3_Senior_Gallery.Pages.ArchaeologyIndexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="Design Archaeology" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="研究 Windows 设计历史，并把可延续的交互 DNA 以现代 Fluent 体验重新表达。历史资料仅用于研究，不在 Gallery 内复制受版权保护的素材。"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="开发占位页"
                Message="Catalog route: /archaeology。各展项会链接到其稳定控件或体验所有者。" />
            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="研究脉络" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Windows Phone / Metro · Zune · Media Center · Windows 8/10/11 · Xbox · Microsoft 365 · Classic Windows · Media Software History" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
