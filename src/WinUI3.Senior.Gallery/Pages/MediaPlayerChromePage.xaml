<Page
    x:Class="WinUI3_Senior_Gallery.Pages.MediaPlayerChromePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:WinUI3.Senior.Media">
    <ScrollViewer>
        <StackPanel MaxWidth="1200" Padding="32,24,32,40" Spacing="16">
            <TextBlock Text="MediaPlayerChrome" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="本地文件调试实验室。文件仅在你主动选择后由宿主加载，控件本身不拥有文件或窗口。" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Open local media" Click="OnOpenLocalMediaClick" />
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="No local media selected." />
            </StackPanel>
            <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <MediaPlayerElement x:Name="PlayerElement" MinHeight="260" AreTransportControlsEnabled="False" AutoPlay="False" />
                    <media:MediaPlayerChrome x:Name="Chrome" PresentationRequested="OnPresentationRequested" CommandCompleted="OnCommandCompleted" />
                </StackPanel>
            </Border>
            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational" Title="P0 boundary"
                     Message="全屏和浮窗仅作为 PresentationRequested 发给宿主；本页不创建或迁移窗口。" />
        </StackPanel>
    </ScrollViewer>
</Page>
