<Page
    x:Class="WinUI3_Senior_Gallery.Pages.GameBarWidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:windowing="using:WinUI3.Senior.Windowing">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="GameBarWidgetExperience" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Host-owned floating widget with reversible click-through mode" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="The fake host demonstrates Interactive/ClickThrough/Minimized state. Click-through always requires an explicit recovery hotkey and host acknowledgement." TextWrapping="Wrap" Opacity="0.72" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Open" Click="OnOpenClick" />
            <Button Content="Close" Click="OnCloseClick" />
            <Button Content="Click-through" Click="OnClickThroughClick" />
            <Button Content="Interactive" Click="OnInteractiveClick" />
            <Button Content="Minimize" Click="OnMinimizeClick" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <windowing:GameBarWidgetExperience x:Name="Widget" WidgetId="gallery-gamebar" InteractionModeRequested="OnInteractionRequested" StateChanged="OnStateChanged">
                <Grid MinHeight="260" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <SymbolIcon Symbol="Play" FontSize="48" />
                        <TextBlock Text="Synthetic Game Bar widget" />
                        <TextBlock Text="Recovery hotkey: Ctrl+Shift+G" Opacity="0.7" />
                    </StackPanel>
                </Grid>
            </windowing:GameBarWidgetExperience>
        </Border>
    </Grid>
</Page>
