<Page
    x:Class="WinUI3_Senior_Gallery.Pages.PlaygroundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="1120" Padding="32,28,32,48" Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Text="Playground" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="为实现 agent 准备的本地交互沙盒" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="/playground · Gallery-owned diagnostics" Opacity="0.65" />
            </StackPanel>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="选择一个场景" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ComboBox x:Name="ScenarioComboBox" ItemsSource="{Binding Scenarios}" DisplayMemberPath="Name" SelectionChanged="OnScenarioChanged" />
                        <TextBlock x:Name="ScenarioDescription" TextWrapping="Wrap" Opacity="0.75" />
                        <TextBlock x:Name="ScenarioContract" Opacity="0.65" Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button Content="运行本地场景" HorizontalAlignment="Left" Click="OnRunClick" />
                        <Button Content="重置状态" HorizontalAlignment="Left" Click="OnResetClick" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="运行参数" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="动画速度" />
                        <Slider x:Name="SpeedSlider" Minimum="0.25" Maximum="2" Value="1" StepFrequency="0.25" ValueChanged="OnSpeedChanged" />
                        <TextBlock x:Name="SpeedLabel" Text="1.00×" Opacity="0.7" />
                        <ToggleSwitch x:Name="AutoRefreshSwitch" Header="自动刷新诊断" IsOn="True" Toggled="OnAutoRefreshToggled" />
                        <ToggleSwitch x:Name="ReducedMotionSwitch" Header="Reduced Motion" Toggled="OnReducedMotionToggled" />
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar x:Name="StatusBar" IsOpen="True" IsClosable="False" Severity="Informational" Title="等待运行" Message="选择一个场景后，运行结果会出现在下方。" />
            <ProgressBar x:Name="RunProgress" Minimum="0" Maximum="100" Value="0" Height="6" />
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="可观测状态" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="StateText" Text="Idle" />
                        <TextBlock x:Name="TickText" Text="ticks: 0" Opacity="0.7" />
                        <TextBlock Text="所有数据仅在当前页面生命周期内存在。" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="实现边界" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="本页不会创建窗口、请求网络、读取文件或写入应用设置。" TextWrapping="Wrap" />
                        <TextBlock Text="ready 才能进入正式控件实现；backlog 只提供可见的实验契约。" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
