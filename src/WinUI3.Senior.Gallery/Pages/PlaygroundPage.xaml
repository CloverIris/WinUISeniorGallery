<Page
    x:Class="WinUI3_Senior_Gallery.Pages.PlaygroundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Playground" />
            <TextBlock TextWrapping="Wrap" Text="Development placeholder for deterministic control experiments. This route will host local scenarios only; it does not own public control APIs." />
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Catalog route"
                Message="/pages/playground" />
        </StackPanel>
    </ScrollViewer>
</Page>
