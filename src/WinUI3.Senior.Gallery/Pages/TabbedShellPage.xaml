<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.TabbedShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <ScrollViewer Padding="32,24,32,40" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1100" Spacing="16">
            <StackPanel Spacing="5">
                <TextBlock Text="TabbedShell" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Sets-style tabs with host-owned tear-out and deterministic lifecycle" Opacity="0.7" />
                <TextBlock Text="Route: /experiences/tabbed-shell" Opacity="0.6" />
            </StackPanel>
            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="Host boundary"
                     Message="The control never creates windows. Tear-out is an explicit request that the host may accept or reject." />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="New tab" Click="OnNewTabClick" />
                <Button Content="Move left" Click="OnMoveLeftClick" />
                <Button Content="Move right" Click="OnMoveRightClick" />
                <Button Content="Close selected" Click="OnCloseClick" />
                <Button Content="Request tear-out" Click="OnTearOutClick" />
            </StackPanel>
            <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <controls:TabbedShell x:Name="Shell" MinHeight="320"
                                      TabClosing="OnTabClosing"
                                      TabClosed="OnTabClosed"
                                      TabReordered="OnTabReordered"
                                      TearOutRequested="OnTearOutRequested" />
            </Border>
            <TextBlock x:Name="StatusText" Text="No tab action yet." TextWrapping="Wrap" Opacity="0.7" />
        </StackPanel>
    </ScrollViewer>
</Page>
