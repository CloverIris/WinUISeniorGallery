<Page
    x:Class="WinUI3_Senior_Gallery.Pages.OverlayMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="OverlayMenu" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Contextual hierarchical menu with modal and non-modal boundaries" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="Esc 先返回父级，再关闭根菜单；宿主拥有项目数据和动作。" Opacity="0.7" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Open modal" Click="OnOpenClick" />
            <Button Content="Open non-modal" Click="OnNonModalClick" />
            <Button Content="Close" Click="OnCloseClick" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="8">
                <TextBlock Text="Navigation model" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Settings、Playback 和 About 均为本地合成菜单；点击带子项的项目只改变 NavigationPath，不触发宿主动作。" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <controls:OverlayMenu x:Name="Menu" Grid.RowSpan="3" />
    </Grid>
</Page>
