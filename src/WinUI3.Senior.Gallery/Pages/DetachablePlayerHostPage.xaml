<Page
    x:Class="WinUI3_Senior_Gallery.Pages.DetachablePlayerHostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:windowing="using:WinUI3.Senior.Windowing">
    <Grid Margin="28" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <StackPanel Spacing="5">
            <TextBlock Text="DetachablePlayerHost" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Host-owned player detach/attach coordinator" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="This lab uses a deterministic fake floating host. The control emits host requests and never creates or moves a Window." TextWrapping="Wrap" Opacity="0.72" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Detach" Click="OnDetachClick" />
            <Button Content="Attach" Click="OnAttachClick" />
            <Button Content="Toggle" Click="OnToggleClick" />
            <Button Content="Simulate owner close" Click="OnOwnerCloseClick" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="2" CornerRadius="12" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <windowing:DetachablePlayerHost x:Name="PlayerHost" PlayerId="gallery-player" StateChanged="OnStateChanged" OperationCompleted="OnOperationCompleted" HostClosed="OnHostClosed">
                <Grid MinHeight="260" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <SymbolIcon Symbol="Play" FontSize="48" />
                        <TextBlock Text="Synthetic player surface" />
                        <TextBlock Text="Content remains host-owned" Opacity="0.7" />
                    </StackPanel>
                </Grid>
            </windowing:DetachablePlayerHost>
        </Border>
    </Grid>
</Page>
