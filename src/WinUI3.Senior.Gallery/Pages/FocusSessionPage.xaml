<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3_Senior_Gallery.Pages.FocusSessionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:senior="using:WinUI3.Senior.Controls">
    <ScrollViewer Padding="32,24,32,40" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="920" Spacing="18">
            <StackPanel Spacing="6">
                <TextBlock Text="Focus Session" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Metro/Windows Clock 专注模式的现代化状态机实验" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Catalog route: /experiences/focus-session" Opacity="0.68" />
            </StackPanel>
            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="宿主中立"
                     Message="计时器只维护阶段、任务和暂停状态，不会改变系统勿扰模式，也不会持久化任务。" />
            <Border Padding="18" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="14">
                    <senior:FocusSession x:Name="Session" Height="260" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Start / Resume" Click="OnStartClick" />
                        <Button Content="Pause" Click="OnPauseClick" />
                        <Button Content="Skip phase" Click="OnSkipClick" />
                        <Button Content="Complete task" Click="OnCompleteTaskClick" />
                        <Button Content="Reset" Click="OnResetClick" />
                    </StackPanel>
                    <TextBlock x:Name="Status" Text="Idle" Opacity="0.68" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
