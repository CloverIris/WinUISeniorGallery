<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:WinUI3.Senior.Media">

    <SolidColorBrush x:Key="MediaTimelineTrackBrush" Color="{ThemeResource ControlStrongFillColorDefault}" />
    <SolidColorBrush x:Key="MediaTimelineProgressBrush" Color="{ThemeResource AccentFillColorDefault}" />
    <SolidColorBrush x:Key="MediaTimelineBufferedBrush" Color="{ThemeResource ControlFillColorSecondary}" />
    <SolidColorBrush x:Key="MediaTimelineDisabledBrush" Color="{ThemeResource ControlFillColorDisabled}" />
    <SolidColorBrush x:Key="MediaTimelineThumbBrush" Color="{ThemeResource AccentFillColorDefault}" />
    <SolidColorBrush x:Key="MediaTimelineMarkerBrush" Color="{ThemeResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="MediaTimelineChapterBrush" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="MediaTimelineLiveBrush" Color="{ThemeResource SystemFillColorCritical}" />
    <x:Double x:Key="MediaTimelineTrackHeight">4</x:Double>
    <x:Double x:Key="MediaTimelineExpandedTrackHeight">6</x:Double>
    <x:Double x:Key="MediaTimelineThumbSize">16</x:Double>

    <Style TargetType="media:MediaTimeline">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="media:MediaTimeline">
                    <Grid x:Name="PART_RootGrid" MinHeight="44">
                        <Grid x:Name="PART_Track" Height="{ThemeResource MediaTimelineTrackHeight}" VerticalAlignment="Center" Background="{ThemeResource MediaTimelineTrackBrush}">
                            <Canvas x:Name="PART_BufferedRangesPresenter" IsHitTestVisible="False" />
                            <Canvas x:Name="PART_DisabledRangesPresenter" IsHitTestVisible="False" />
                            <Rectangle x:Name="PART_Progress" HorizontalAlignment="Left" Fill="{ThemeResource MediaTimelineProgressBrush}" />
                            <Canvas x:Name="PART_ChapterPresenter" IsHitTestVisible="False" />
                            <Canvas x:Name="PART_MarkerPresenter" IsHitTestVisible="False" />
                            <Thumb x:Name="PART_Thumb" Width="{ThemeResource MediaTimelineThumbSize}" Height="{ThemeResource MediaTimelineThumbSize}" HorizontalAlignment="Left" Background="{ThemeResource MediaTimelineThumbBrush}" />
                        </Grid>
                        <ToolTip x:Name="PART_ToolTip" />
                        <TextBlock x:Name="PART_TimeText" HorizontalAlignment="Right" VerticalAlignment="Top" />
                        <TextBlock x:Name="PART_PlaybackRateText" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <TextBlock x:Name="PART_LiveBadge" Text="Live" Foreground="{ThemeResource MediaTimelineLiveBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                        <Button x:Name="PART_GoLiveButton" Content="Go live" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Idle" />
                                <VisualState x:Name="ReadOnly" />
                                <VisualState x:Name="Unavailable" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="InteractionStates">
                                <VisualState x:Name="Scrubbing" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="TimelineModeStates">
                                <VisualState x:Name="VideoOnDemand" />
                                <VisualState x:Name="Live" />
                                <VisualState x:Name="LiveDvr" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="LiveStates">
                                <VisualState x:Name="AtLiveEdge" />
                                <VisualState x:Name="NotAtLiveEdge" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
