<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls">

    <SolidColorBrush x:Key="CarouselViewBackground" Color="{ThemeResource SystemControlBackgroundBaseLowColor}" />
    <SolidColorBrush x:Key="CarouselViewIndicatorForeground" Color="{ThemeResource SystemControlForegroundBaseMediumColor}" />
    <SolidColorBrush x:Key="CarouselViewIndicatorSelectedForeground" Color="{ThemeResource SystemControlHighlightAltAccentColor}" />
    <x:Double x:Key="CarouselViewItemSpacing">0</x:Double>
    <Duration x:Key="CarouselViewTransitionDuration">0:0:0.25</Duration>
    <CornerRadius x:Key="CarouselViewCornerRadius">8</CornerRadius>

    <Style x:Key="CarouselViewNavigationButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style TargetType="controls:CarouselView">
        <Setter Property="Background" Value="{ThemeResource CarouselViewBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:CarouselView">
                    <Grid x:Name="PART_Root" Background="{TemplateBinding Background}">
                        <ItemsRepeater x:Name="PART_Repeater" />

                        <Button x:Name="PART_PreviousButton"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{ThemeResource CarouselViewNavigationButtonStyle}"
                                AutomationProperties.Name="Previous item"
                                Content="&#xE72B;" />
                        <Button x:Name="PART_NextButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{ThemeResource CarouselViewNavigationButtonStyle}"
                                AutomationProperties.Name="Next item"
                                Content="&#xE72A;" />
                        <ContentPresenter x:Name="PART_IndicatorPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,0,12" />
                        <TextBlock x:Name="PART_LiveRegion"
                                   AutomationProperties.LiveSetting="Polite"
                                   Opacity="0"
                                   IsHitTestVisible="False" />

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_PreviousButton" Storyboard.TargetProperty="Opacity">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="1" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_NextButton" Storyboard.TargetProperty="Opacity">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="1" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="NavigationStates">
                                <VisualState x:Name="CanPrevious" />
                                <VisualState x:Name="CanNext" />
                                <VisualState x:Name="SingleItem" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="InteractionStates">
                                <VisualState x:Name="Idle" />
                                <VisualState x:Name="Dragging" />
                                <VisualState x:Name="Settling" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
