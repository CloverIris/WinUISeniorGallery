<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinUI3.Senior.Samples.ControlsMinimal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3.Senior.Controls"
    Title="WinUI 3 Senior Gallery — CarouselView Lab">
    <ScrollViewer>
        <StackPanel x:Name="PageRoot" Spacing="16" Padding="24" MaxWidth="1100">
            <TextBlock Text="CarouselView lab" Style="{StaticResource TitleTextBlockStyle}" />
            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="Unpackaged development sample"
                     Message="Uses local deterministic data only. Requires the Windows App SDK 2.2 runtime; it is separate from the packaged Gallery." />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox x:Name="ItemCountBox" Header="Items" Width="150" SelectionChanged="OnSettingsChanged">
                    <ComboBoxItem Content="5" />
                    <ComboBoxItem Content="20" />
                    <ComboBoxItem Content="1000" />
                </ComboBox>
                <ComboBox x:Name="NavigationModeBox" Header="Navigation" Width="150" SelectionChanged="OnSettingsChanged">
                    <ComboBoxItem Content="Bounded" />
                    <ComboBoxItem Content="Loop" />
                </ComboBox>
                <ComboBox x:Name="TransitionBox" Header="Transition" Width="150" SelectionChanged="OnSettingsChanged">
                    <ComboBoxItem Content="Slide" />
                    <ComboBoxItem Content="Fade" />
                    <ComboBoxItem Content="CoverFlow" />
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ToggleSwitch x:Name="AutoplayToggle" Header="Autoplay" Toggled="OnSettingsChanged" />
                <ToggleSwitch x:Name="PreviewToggle" Header="Adjacent preview" Toggled="OnSettingsChanged" />
                <ToggleSwitch x:Name="RtlToggle" Header="RTL" Toggled="OnSettingsChanged" />
                <ToggleSwitch x:Name="ReducedMotionToggle" Header="Reduced motion preview" Toggled="OnSettingsChanged" />
            </StackPanel>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button VerticalAlignment="Center" Click="OnPreviousClick" Content="Previous" />
                <Border Grid.Column="1" MinHeight="340" CornerRadius="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <controls:CarouselView x:Name="Carousel" SelectionChanged="OnCarouselSelectionChanged" ItemInvoked="OnCarouselItemInvoked">
                        <controls:CarouselView.ItemTemplate>
                            <DataTemplate>
                                <Border MinHeight="280" Margin="8" Padding="24" CornerRadius="12" Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <StackPanel VerticalAlignment="Center" Spacing="8">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextBlockStyle}" />
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </controls:CarouselView.ItemTemplate>
                    </controls:CarouselView>
                </Border>
                <Button Grid.Column="2" VerticalAlignment="Center" Click="OnNextClick" Content="Next" />
            </Grid>
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Window>
